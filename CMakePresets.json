{
  "version": 3,
  "configurePresets": [
    {
      "name": "non-cuda",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "USE_CUDA": "OFF",
        "BUILD_LIBRARY": "ON",
        "BUILD_TESTS": "ON",
        "INSTALL_DEVEL": "ON",
        "BUILD_PYTHON": "ON",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/install"
      }
    },
    {
      "name": "docs",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/docs/_build_doxygen",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "USE_CUDA": "OFF",
        "BUILD_LIBRARY": "ON",
        "BUILD_TESTS": "OFF",
        "INSTALL_DEVEL": "ON",
        "BUILD_PYTHON": "ON",
        "BUILD_DOCS": "ON",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/install"
      }
    },
    {
      "name": "cuda",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "USE_CUDA": "ON",
        "CMAKE_CUDA_ARCHITECTURES": "native",
        "BUILD_LIBRARY": "ON",
        "BUILD_TESTS": "ON",
        "BUILD_PYTHON": "ON",
        "INSTALL_DEVEL": "ON",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/install"
      }
    },
    {
      "name": "cuda12",
      "inherits": "cuda",
      "binaryDir": "${sourceDir}/build-cuda12",
      "cacheVariables": {
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/install-cuda12"
      }
    },
    {
      "name": "cuda13",
      "inherits": "cuda",
      "binaryDir": "${sourceDir}/build-cuda13",
      "cacheVariables": {
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/install-cuda13"
      }
    }
  ]
}
